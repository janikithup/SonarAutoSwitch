<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:viewModels="clr-namespace:Sonar.AutoSwitch.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Sonar.AutoSwitch.Pages.Settings"
             x:CompileBindings="True"
             x:DataType="viewModels:SettingsViewModel">

    <StackPanel>
        <TextBlock Text="Settings" Theme="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8" />
        <ui:SettingsExpander IconSource="Accept" Header="Enabled" IsExpanded="True"
                             Description="Enable or disable Sonar Auto Switch"
                             IsClickEnabled="False">
            <ui:SettingsExpander.Footer>
                <ToggleSwitch IsChecked="{Binding Enabled}" />
            </ui:SettingsExpander.Footer>
        </ui:SettingsExpander>
        <ui:SettingsExpander IconSource="RotateClockwise" Header="Start at startup" IsExpanded="True"
                             Description="{Binding StartupDescription}"
                             IsClickEnabled="False">
            <ui:SettingsExpander.Footer>
                <ToggleSwitch IsChecked="{Binding StartAtStartup}" />
            </ui:SettingsExpander.Footer>
        </ui:SettingsExpander>
        <ui:SettingsExpander IconSource="Cloud" Header="Use GitHub profiles" IsExpanded="True"
                             Description="Use profiles set by users in GitHub"
                             IsClickEnabled="False">
            <ui:SettingsExpander.Footer>
                <ToggleSwitch IsChecked="{Binding UseGithubConfigs}" />
            </ui:SettingsExpander.Footer>
        </ui:SettingsExpander>
        <ui:SettingsExpander IconSource="HiddenMirrored" Header="Close to tray" IsExpanded="True"
                             Description="Closing the window hides to tray instead of exiting"
                             IsClickEnabled="False">
            <ui:SettingsExpander.Footer>
                <ToggleSwitch AutomationProperties.Name="CloseToTray" IsChecked="{Binding CloseToTray}" />
            </ui:SettingsExpander.Footer>
        </ui:SettingsExpander>

        <Rectangle Height="1" Fill="{DynamicResource CardStrokeColorDefaultBrush}" Margin="0,16,0,12" />

        <!-- Version + update check -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
            <TextBlock x:Name="VersionLabel" VerticalAlignment="Center" />
            <Button Content="Copy" Click="CopyVersion_Click" Padding="8,3" FontSize="12"
                    AutomationProperties.Name="Copy version" />
            <Button Content="Check for updates" Click="CheckUpdates_Click" Padding="8,3" FontSize="12"
                    AutomationProperties.Name="Check for updates" />
            <TextBlock x:Name="UpdateStatus" VerticalAlignment="Center" Opacity="0.6" FontSize="12" />
        </StackPanel>

        <!-- Troubleshooting -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
            <Button Content="Open log file" Click="OpenLog_Click"
                    AutomationProperties.Name="Open log file" />
            <Button Content="Open config folder" Click="OpenFolder_Click"
                    AutomationProperties.Name="Open config folder" />
        </StackPanel>

        <!-- Reset -->
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="ResetButton" Content="Reset to defaults" Click="Reset_Click"
                    Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                    AutomationProperties.Name="Reset to defaults" />
        </StackPanel>
        <StackPanel x:Name="ResetConfirmPanel" IsVisible="False" Orientation="Horizontal"
                    Spacing="8" Margin="0,8,0,0">
            <TextBlock Text="Delete all profiles and settings?" VerticalAlignment="Center" Opacity="0.8" />
            <Button Content="Yes, reset everything" Click="ResetConfirm_Click"
                    Foreground="{DynamicResource SystemFillColorCriticalBrush}" />
            <Button Content="Cancel" Click="ResetCancel_Click" />
        </StackPanel>

    </StackPanel>

</UserControl>
